# 3D Civil Works Configuration

# === BACKEND SETTINGS ===

# Server settings
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# File storage
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# Model configuration (for future integration)
DEPTH_MODEL_PATH=./models/depth_model
MESH_GEN_MODEL_PATH=./models/mesh_model

# Processing parameters
MAX_INPUT_RESOLUTION=1024
DEPTH_SCALE=1.0
MESH_SIMPLIFICATION=0.5

# Compute device (cpu, cuda, mps - Metal Performance Shaders on Apple Silicon)
DEVICE=cpu

# CORS settings (restrict in production)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# === FRONTEND SETTINGS ===

# API server URL - uncomment and set to your backend URL
# For local development, leave commented to use default (http://localhost:8000)
# For deployed environments, set to your backend API URL:
# API_BASE_URL=https://api.example.com
